<?xml version="1.0" encoding="UTF-8"?>

<!-- Browser E2E: committed DB writes must be visible across reloads — omit DAMA. -->
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         colors="true"
         bootstrap="tests/bootstrap.php"
         cacheDirectory=".phpunit.cache"
>
    <php>
        <ini name="display_errors" value="1" />
        <ini name="error_reporting" value="-1" />
        <ini name="memory_limit" value="512M" />
        <server name="APP_ENV" value="test" force="true" />
        <server name="SHELL_VERBOSITY" value="-1" />
        <env name="KERNEL_CLASS" value="App\Kernel" />
        <env name="DATABASE_URL" value="mysql://live-grid_user:live-grid_pass@db_e2e:3306/live-grid_e2e?serverVersion=mariadb-10.2.44&amp;charset=utf8mb4" force="true" />
    </php>

    <testsuites>
        <testsuite name="E2E Smoke">
            <directory>tests/E2e/Smoke</directory>
        </testsuite>
        <testsuite name="E2E UserList">
            <directory>tests/E2e/Admin</directory>
        </testsuite>
    </testsuites>

    <extensions>
        <bootstrap class="Zenstruck\Foundry\PHPUnit\FoundryExtension" />
    </extensions>
</phpunit>
