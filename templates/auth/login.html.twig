{% extends 'auth.html.twig' %}
{% block title %}{{ 'auth.page_title'|trans }}{% endblock %}
{% block body %}
    <div class="app-wrapper">

        <div class="auth-wrapper">

            <div class="auth-wrapper-inner is-single">

                <div class="auth-nav">
                    <div class="left"></div>
                    <div class="center">
                        <a href="/" class="header-item">
                            <img class="light-image" src="assets/img/logos/logo/logo.svg" alt="">
                            <img class="dark-image" src="assets/img/logos/logo/logo-light.svg" alt="">
                        </a>
                    </div>
                    <div class="right">
                        <label class="dark-mode ml-auto">
                            <input type="checkbox" checked>
                            <span></span>
                        </label>
                    </div>
                </div>

                <div class="single-form-wrap">

                    <div class="inner-wrap">
                        <div class="auth-head">
                            <h2>{{ 'auth.welcome_back'|trans }}</h2>
                            <p>{{ 'auth.sign_in_into_account'|trans }}</p>
                            <a href="/auth-signup-3.html">{{ 'auth.i_do_not_have_account'|trans }}</a>
                        </div>

                        <div class="form-card">
                            {% if error %}
                                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                            {% endif %}
                            <form method="post">
                                <div id="signin-form" class="login-form">
                                    <div class="field">
                                        <div class="control has-icon">
                                            <input class="input" type="text" placeholder="{{ 'auth.form.username_placeholder'|trans }}" name="email"
                                                   value="{{ last_username }}" required autofocus/>
                                            <span class="form-icon"><i data-feather="user"></i></span>
                                        </div>
                                    </div>
                                    <div class="field">
                                        <div class="control has-icon">
                                            <input class="input" type="password" placeholder="{{ 'auth.form.password_placeholder'|trans }}"
                                                   name="password"/>
                                            <span class="form-icon"><i data-feather="lock"></i></span>
                                        </div>
                                    </div>

                                    <div class="setting-item">
                                        <label class="form-switch is-primary">
                                            <input type="checkbox" class="is-switch" id="busy-mode-toggle">
                                            <i></i>
                                        </label>
                                        <div class="setting-meta">
                                            <span>{{ 'auth.remember_me'|trans }}</span>
                                        </div>
                                    </div>

                                    <div class="control login">
                                        <button class="button h-button is-primary is-bold is-fullwidth is-raised">
                                            {{ 'auth.sign_in'|trans }}
                                        </button>
                                    </div>
                                </div>
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                            </form>
                        </div>

                        <div class="forgot-link has-text-centered">
                            <a>{{ 'auth.forgot_password'|trans }}</a>
                        </div>

                    </div>

                </div>

            </div>
        </div>
    </div>
{% endblock %}
